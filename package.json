{
	"name": "react-chromecast-caf",
	"version": "0.0.3",
	"description": "React hooks to use the Chromecast sender and receiver SDK in your project.",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"scripts": {
		"start": "rollup -c -w",
		"dev": "npm start",
		"build": "rollup -c",
		"prepare": "npm run build"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/FilipChalupa/react-chromecast-caf.git"
	},
	"keywords": [
		"chromecast",
		"sender",
		"receiver",
		"typescript",
		"react"
	],
	"author": {
		"name": "Filip Chalupa",
		"email": "chalupa.filip@gmail.com",
		"url": "https://www.npmjs.com/~onset"
	},
	"license": "ISC",
	"peerDependencies": {
		"react": "18 || 19"
	},
	"files": [
		"/dist/"
	],
	"devDependencies": {
		"@rollup/plugin-commonjs": "^25.0.8",
		"@rollup/plugin-node-resolve": "^15.0.1",
		"@types/react": "^18.0.26",
		"react": "^18.2.0",
		"rollup": "^4.59.0",
		"rollup-plugin-copy": "^3.5.0",
		"rollup-plugin-delete": "^3.0.2",
		"rollup-plugin-peer-deps-external": "^2.2.4",
		"rollup-plugin-typescript2": "^0.36.0",
		"typescript": "^5.9.3",
		"tslib": "^2.8.1"
	},
	"dependencies": {
		"@types/chromecast-caf-receiver": "^6.0.25",
		"@types/chromecast-caf-sender": "^1.0.11"
	}
}
