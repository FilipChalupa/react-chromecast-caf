{
	"compilerOptions": {
		"declaration": true,
		"declarationDir": "dist",
		"module": "esnext",
		"target": "es5",
		"lib": ["es6", "dom", "es2016", "es2017"],
		"sourceMap": true,
		"jsx": "react",
		"moduleResolution": "node",
		"allowSyntheticDefaultImports": true,
		"strictNullChecks": true,
		"esModuleInterop": true,
		"paths": {
			"cast-receiver-module": ["./src/types/cast-shim.d.ts"],
			"cast-sender-module": ["./src/types/cast-shim.d.ts"]
		},
		"types": []
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist"]
}
